# ==========================================
# Ornaq Frontend Environment Configuration
# ==========================================

# Backend API base URL (must NOT end with /api — the client appends it)
# Production:
VITE_API_URL=https://ornaq-backend-j3eg.onrender.com

# Development:
# VITE_API_URL=http://localhost:5000

# ==========================================
# Socket.IO (optional — falls back to VITE_API_URL if not set)
# ==========================================
# VITE_SOCKET_URL=https://ornaq-backend-j3eg.onrender.com

# ==========================================
# Google OAuth Client ID
# Get this from Google Cloud Console > APIs & Services > Credentials
# Must match the GOOGLE_CLIENT_ID configured on the backend
# ==========================================
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

